using System;
using UnityEditor.Experimental.GraphView;
using UnityEngine;
using UnityEngine.InputSystem;

public class GameManager : MonoBehaviour
{

    [SerializeField] private int vida = 30;
    [SerializeField] private bool tieneEspadaFuego = false;

    // Start is called once before the first execution of Update after the MonoBehaviour is created
    void Start()
    {
        if (tieneEspadaFuego == true && vida >= 25)
        {
            Debug.Log("Puedes entrar al Volcan Infernal");
        }
        else
        {
            Debug.Log("No estas preparado para el Volcan Infernal");
        }

        

    }

    // Update is called once per frame
    void Update()
    {
       if (Keyboard.current.spaceKey.wasPressedThisFrame)
        {
            Debug.Log("Has pulsado la barra espaciadora, buen trabajo :)");
        }




    }
}
